# ── Wallet ────────────────────────────────────────────────────────────────────
# NEVER commit a real private key.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── RPC — Linea Mainnet (public endpoint works, or use Infura/Alchemy) ────────
RPC_URL=https://rpc.linea.build

# ── Token Identity ────────────────────────────────────────────────────────────
TOKEN_NAME=Money Access Crypto
TOKEN_SYMBOL=MAC
TOKEN_INITIAL_SUPPLY=1000000

# ── Block Explorer API Keys (for contract verification, optional) ─────────────
# Get a free Lineascan API key at https://lineascan.build/myapikey
LINEASCAN_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
REPORT_GAS=false
